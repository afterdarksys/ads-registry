{
    "server": {
        "address": "0.0.0.0",
        "port": 5005,
        "read_timeout": 300000000000,
        "write_timeout": 300000000000,
        "idle_timeout": 120000000000,
        "read_header_timeout": 10000000000,
        "tls": {
            "enabled": true,
            "port": 5006,
            "cert_file": "certs/server.crt",
            "key_file": "certs/server.key"
        }
    },
    "database": {
        "driver": "sqlite3",
        "dsn": "data/registry.db",
        "max_open_conns": 25,
        "max_idle_conns": 5,
        "conn_max_lifetime": 3600000000000
    },
    "storage": {
        "driver": "local",
        "local": {
            "root_directory": "data/blobs"
        },
        "s3": {
            "region": "us-west-2",
            "bucket": "ads-registry-blobs",
            "access_key_id": "",
            "secret_access_key": "",
            "endpoint": ""
        },
        "minio": {
            "endpoint": "localhost:9000",
            "access_key_id": "minioadmin",
            "secret_access_key": "minioadmin",
            "bucket": "registry",
            "use_ssl": false,
            "region": "us-east-1"
        },
        "oci": {
            "namespace": "your-oci-namespace",
            "bucket": "ads-registry",
            "region": "us-phoenix-1",
            "compartment_id": "ocid1.compartment.oc1...",
            "tenancy_id": "ocid1.tenancy.oc1...",
            "user_id": "ocid1.user.oc1...",
            "fingerprint": "aa:bb:cc:dd:ee:ff:11:22:33:44:55:66:77:88:99:00",
            "private_key_path": "/path/to/oci_api_key.pem",
            "private_key": "",
            "endpoint": ""
        }
    },
    "auth": {
        "token_issuer": "ads-registry",
        "token_service": "registry",
        "private_key_path": "",
        "public_key_path": ""
    },
    "logging": {
        "syslog": {
            "enabled": false,
            "server": "local",
            "tag": "ads-registry",
            "priority": "INFO"
        },
        "elasticsearch": {
            "enabled": false,
            "endpoint": "http://localhost:9200",
            "index": "ads-registry",
            "username": "",
            "password": ""
        }
    },
    "vault": {
        "enabled": false,
        "address": "http://localhost:8200",
        "token": "",
        "mount_path": "secret",
        "key_path": "ads-registry/jwt-keys"
    },
    "queue": {
        "enabled": true,
        "vulnerability_queue": 4,
        "periodic_queue": 1,
        "default_queue": 2
    },
    "redis": {
        "enabled": true,
        "address": "localhost:6379",
        "password": "",
        "db": 0,
        "ttl": {
            "manifest": 300,
            "signature": 300,
            "scan_report": 3600,
            "policy": 300
        }
    }
}