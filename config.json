{
  "server": {
    "address": "0.0.0.0",
    "port": 5050,
    "read_timeout": 10000000000,
    "write_timeout": 10000000000,
    "idle_timeout": 60000000000,
    "read_header_timeout": 5000000000,
    "max_header_bytes": 10485760,
    "tls": {
      "enabled": false,
      "port": 5006,
      "cert_file": "certs/server.crt",
      "key_file": "certs/server.key"
    }
  },
  "database": {
    "driver": "postgres",
    "dsn": "postgres://ads_user:password@localhost:5432/ads_registry?sslmode=disable",
    "max_open_conns": 100,
    "max_idle_conns": 10,
    "conn_max_lifetime": 3600000000000
  },
  "storage": {
    "driver": "local",
    "local": {
      "root_directory": "data/blobs"
    }
  },
  "auth": {
    "token_issuer": "ads-registry",
    "token_service": "registry",
    "private_key_path": "keys/private.key",
    "public_key_path": "keys/public.key",
    "token_expiration": 86400000000000,
    "oidc": {
      "enabled": false,
      "issuer": "",
      "client_id": "",
      "client_secret": "",
      "redirect_url": "",
      "scopes": []
    }
  },
  "logging": {
    "level": "info",
    "syslog": {
      "enabled": false,
      "server": "",
      "tag": "ads-registry",
      "priority": "INFO"
    },
    "elasticsearch": {
      "enabled": false,
      "endpoint": "",
      "index": "",
      "username": "",
      "password": ""
    }
  },
  "vault": {
    "enabled": false,
    "address": "",
    "token": "",
    "mount_path": "",
    "key_path": ""
  },
  "webhooks": [],
  "queue": {
    "enabled": true,
    "vulnerability_queue": 4,
    "periodic_queue": 1,
    "default_queue": 2
  },
  "redis": {
    "enabled": true,
    "address": "localhost:6379",
    "password": "",
    "db": 0,
    "ttl": {
      "manifest": 300,
      "signature": 300,
      "scan_report": 3600,
      "policy": 300
    }
  },
  "compatibility": {
    "enabled": true,
    "docker_client_workarounds": {
      "enable_docker_29_manifest_fix": true,
      "force_http1_for_manifests": false,
      "disable_chunked_encoding": false,
      "max_manifest_size": 10485760,
      "extra_flushes": 3,
      "header_write_delay_ms": 0
    },
    "protocol_emulation": {
      "emulate_docker_registry_v2": true,
      "emulate_distribution_v3": false,
      "expose_oci_features": true,
      "strict_mode": false
    },
    "broken_client_hacks": {
      "podman_digest_workaround": false,
      "skopeo_layer_reuse": false,
      "crane_manifest_format": "auto",
      "containerd_content_length": false,
      "buildkit_parallel_upload": false,
      "nerdctl_missing_headers": false
    },
    "tls_compatibility": {
      "min_tls_version": "1.2",
      "enable_legacy_ciphers": false,
      "http2_enabled": true,
      "force_http1_for_clients": [],
      "alpn_protocols": [
        "h2",
        "http/1.1"
      ]
    },
    "header_workarounds": {
      "always_send_distribution_api_version": true,
      "content_type_fixups": false,
      "location_header_format": "absolute",
      "enable_cors": false,
      "accept_malformed_accept": false,
      "normalize_digest_header": false
    },
    "rate_limit_exceptions": {
      "trusted_registries": [],
      "cicd_user_agents": [],
      "trusted_ip_ranges": [],
      "bypass_for_authenticated": false
    },
    "observability": {
      "log_workarounds": true,
      "log_client_detection": true,
      "enable_metrics": true,
      "metrics_prefix": "ads_registry_compat_",
      "log_sample_rate": 1.0,
      "log_success_only": false
    },
    "enable_streaming_translation": true,
    "translation_direction": "both"
  },
  "peers": [],
  "darkscan": {
    "enabled": false,
    "base_url": "https://darkapi.io",
    "api_key": "",
    "scan_on_push": false,
    "scan_on_pull": false,
    "block_on_critical": false,
    "block_on_high": false,
    "max_concurrent": 5,
    "timeout": 300
  }
}
