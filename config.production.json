{
    "server": {
        "address": "0.0.0.0",
        "port": 5005,
        "read_timeout": 300000000000,
        "write_timeout": 300000000000,
        "idle_timeout": 120000000000,
        "read_header_timeout": 10000000000,
        "tls": {
            "enabled": true,
            "port": 5006,
            "cert_file": "certs/server.crt",
            "key_file": "certs/server.key"
        }
    },
    "database": {
        "driver": "postgres",
        "dsn": "postgres://ads_registry:ads_registry_password@localhost:5434/ads_registry?sslmode=disable",
        "max_open_conns": 25,
        "max_idle_conns": 5,
        "conn_max_lifetime": 3600000000000
    },
    "storage": {
        "driver": "local",
        "local": {
            "root_directory": "/opt/ads-registry/data/blobs"
        }
    },
    "auth": {
        "token_issuer": "ads-registry",
        "token_service": "registry",
        "private_key_path": "",
        "public_key_path": "",
        "token_expiration": 259200000000000
    },
    "logging": {
        "level": "info",
        "syslog": {
            "enabled": false,
            "server": "local",
            "tag": "ads-registry",
            "priority": "INFO"
        },
        "elasticsearch": {
            "enabled": false,
            "endpoint": "http://localhost:9200",
            "index": "ads-registry",
            "username": "",
            "password": ""
        }
    },
    "vault": {
        "enabled": false,
        "address": "http://localhost:8200",
        "token": "",
        "mount_path": "secret",
        "key_path": "ads-registry/jwt-keys"
    },
    "queue": {
        "enabled": true,
        "vulnerability_queue": 4,
        "periodic_queue": 1,
        "default_queue": 2
    },
    "redis": {
        "enabled": false,
        "address": "localhost:6379",
        "password": "",
        "db": 0,
        "ttl": {
            "manifest": 300,
            "signature": 300,
            "scan_report": 3600,
            "policy": 300
        }
    },
    "darkscan": {
        "enabled": false,
        "base_url": "https://darkapi.io",
        "api_key": "",
        "scan_on_push": true,
        "scan_on_pull": false,
        "block_on_critical": false,
        "block_on_high": false,
        "max_concurrent": 5,
        "timeout": 300
    }
}
